{
  "name": "swag-labs",
  "version": "1.0.0",
  "description": "Automation project for saucedemo.com with Cypress, accessibility testing, and Allure reporting",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:headed": "cypress run --headed",
    "cypress:run:spec": "cypress run --spec",
    "allure:generate": "allure generate",
    "allure:open": "allure open",
    "test:allure": "cypress run --env allure=true",
    "test:accessibility": "cypress run --spec 'cypress/e2e/**/*accessibility*.cy.ts'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "cypress",
    "automation",
    "testing",
    "accessibility",
    "a11y",
    "swaglabs"
  ],
  "author": "Bruno Pulis",
  "license": "ISC",
  "packageManager": "pnpm@10.28.1",
  "devDependencies": {
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "allure-commandline": "^2.37.0",
    "axe-core": "^4.11.1",
    "cypress": "^15.11.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.1.0",
    "prettier": "^3.8.1"
  }
}
